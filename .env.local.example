# Supabase (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (api-server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API server token (must match MC_API_TOKEN on the server)
MC_API_TOKEN=your-mc-api-token

# Frontend
NEXT_PUBLIC_API_URL=https://api.ccxmc.ca
NEXT_PUBLIC_MC_API_TOKEN=your-mc-api-token
